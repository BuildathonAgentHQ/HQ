# ═══════════════════════════════════════════════════════════════════════════════
#  Agent HQ — Environment Configuration
#  Copy this file to .env and fill in the values you have.
#  All services degrade gracefully when keys are missing.
# ═══════════════════════════════════════════════════════════════════════════════

# ── NVIDIA Nemotron (agent output → plain English translation) ───────────────
# Get a key at https://build.nvidia.com → Nemotron
NEMOTRON_API_KEY=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
NEMOTRON_API_URL=https://integrate.api.nvidia.com/v1

# ── Nia MCP Server (context / knowledge retrieval) ───────────────────────────
NIA_MCP_URL=http://localhost:3001

# ── GitHub (PR risk analysis, coverage, repo health) ─────────────────────────
GITHUB_TOKEN=
GITHUB_REPO=owner/repo

# ── Databricks / MLflow (telemetry & experiment tracking) ────────────────────
DATABRICKS_HOST=
DATABRICKS_TOKEN=
MLFLOW_TRACKING_URI=sqlite:///mlruns.db

# ── Budget defaults ─────────────────────────────────────────────────────────
BUDGET_LIMIT_PER_TASK=2.0

# ── Server ───────────────────────────────────────────────────────────────────
WS_PORT=8000
FRONTEND_URL=http://localhost:3000

# ── Feature flags ────────────────────────────────────────────────────────────
# Set to true to enable real integrations. Default (false) = use mocks.
USE_NEMOTRON=false
USE_NIA_MCP=false
USE_DATABRICKS=false
USE_GITHUB=false

NIA_API_KEY=nk_IOpF4