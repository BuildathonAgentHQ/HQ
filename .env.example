# ── Anthropic (Claude Code engine) ────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── NVIDIA Nemotron (translation layer) ───────────────────────────────────────
NEMOTRON_API_KEY=
NEMOTRON_API_URL=

# ── Nia MCP Server ────────────────────────────────────────────────────────────
NIA_MCP_URL=
NIA_API_KEY=

# ── Databricks / MLflow ───────────────────────────────────────────────────────
