DATABRICKS_TOKEN=
MLFLOW_TRACKING_URI=

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_REPO=

# ── Budgets ───────────────────────────────────────────────────────────────────
BUDGET_LIMIT_PER_TASK=

# ── Server ────────────────────────────────────────────────────────────────────
WS_PORT=
FRONTEND_URL=

# ── Feature flags (all enabled — real services configured) ────────────────────
USE_NEMOTRON=
USE_NIA_MCP=
USE_DATABRICKS=
USE_GITHUB=
USE_CLAUDE_API=

# ── Claude API ────────────────────────────────────────────────────────────────
