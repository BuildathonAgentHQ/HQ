# ═══════════════════════════════════════════════════════════════════════════════
#  Agent HQ — Environment Configuration (example)
#
#  Copy this file to .env and fill in your real values.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Anthropic (Claude Code engine + Claude API) ───────────────────────────────
# Required for the Claude intelligence engine. Get your key at:
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-YOUR-KEY-HERE

# ── NVIDIA Nemotron (translation layer) ───────────────────────────────────────
NEMOTRON_API_KEY=
NEMOTRON_API_URL=https://integrate.api.nvidia.com/v1

# ── Nia MCP Server ────────────────────────────────────────────────────────────
NIA_MCP_URL=http://localhost:3001
NIA_API_KEY=

# ── Databricks / MLflow ───────────────────────────────────────────────────────
DATABRICKS_HOST=
DATABRICKS_TOKEN=
MLFLOW_TRACKING_URI=sqlite:///mlruns.db

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_REPO=

# ── Budgets ───────────────────────────────────────────────────────────────────
BUDGET_LIMIT_PER_TASK=2.0

# ── Server ────────────────────────────────────────────────────────────────────
WS_PORT=8000
FRONTEND_URL=http://localhost:3000

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set to true once real service credentials are configured.
USE_NEMOTRON=false
USE_NIA_MCP=false
USE_DATABRICKS=false
USE_GITHUB=false
USE_CLAUDE_API=true

# ── Claude API ────────────────────────────────────────────────────────────────
# Model to use for all Claude API calls. Default: claude-sonnet-4-20250514
CLAUDE_MODEL=claude-sonnet-4-20250514